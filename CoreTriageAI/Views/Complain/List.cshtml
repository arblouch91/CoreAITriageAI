@model CoreTriageAI.Models.ComplainListViewModel
@{
    ViewData["Title"] = "All Complaints";

    var departments = new[]
    {
        "Fraud / Billing Team",
        "Digital Banking Support",
        "Relationship Management",
        "Card Operations"
    };

    var categories = new[] { "Fraud", "Fees", "Service Downtime", "Card Issue" };

    var statuses = new[] { "Open", "In Progress", "Resolved" };

    var sortOptions = new (string? Value, string Label)[]
    {
        (null,            "Most Recent"),
        ("date_asc",      "Oldest First"),
        ("priority_desc", "Priority: High → Low"),
        ("priority_asc",  "Priority: Low → High"),
        ("category_asc",  "Category: A → Z"),
        ("category_desc", "Category: Z → A"),
        ("status_asc",    "Status: A → Z"),
        ("status_desc",   "Status: Z → A")
    };

    var startPage = Math.Max(1, Model.CurrentPage - 2);
    var endPage   = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
}

<!-- Page Header -->
<div class="sw-page-header">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
            <h1>All Complaints</h1>
            <p>Monitor and manage AI-triaged customer complaints</p>
        </div>
        <a class="sw-btn sw-btn-primary" asp-controller="Complain" asp-action="Index">
            <i data-lucide="plus"></i>
            New Complaint
        </a>
    </div>
</div>

<!-- Stats Row -->
<div class="sw-stats-row">
    <div class="sw-stat-card">
        <div class="sw-stat-icon">
            <i data-lucide="inbox"></i>
        </div>
        <div class="sw-stat-body">
            <div class="sw-stat-value">@Model.TotalCount</div>
            <div class="sw-stat-label">Total Complaints</div>
        </div>
    </div>

    <div class="sw-stat-card">
        <div class="sw-stat-icon" style="background: rgba(239,68,68,0.1); color: #ef4444;">
            <i data-lucide="alert-triangle"></i>
        </div>
        <div class="sw-stat-body">
            <div class="sw-stat-value">@Model.HighPriorityCount</div>
            <div class="sw-stat-label">High Priority</div>
        </div>
    </div>

    <div class="sw-stat-card">
        <div class="sw-stat-icon" style="background: rgba(16,185,129,0.1); color: #10b981;">
            <i data-lucide="activity"></i>
        </div>
        <div class="sw-stat-body">
            <div class="sw-stat-value">@((Model.AvgSentiment * 100).ToString("F0"))%</div>
            <div class="sw-stat-label">Avg. Sentiment</div>
        </div>
    </div>
</div>

<!-- Filter Bar -->
<div class="sw-filter-bar">
    <form method="get" asp-controller="Complain" asp-action="List">
        <div class="sw-filter-row">

            <div class="sw-filter-group">
                <label class="sw-filter-label">Department</label>
                <select name="department" class="sw-select">
                    <option value="">All Departments</option>
                    @foreach (var dept in departments)
                    {
                        if (Model.Department == dept) { <option value="@dept" selected>@dept</option> }
                        else { <option value="@dept">@dept</option> }
                    }
                </select>
            </div>

            <div class="sw-filter-group">
                <label class="sw-filter-label">Category</label>
                <select name="category" class="sw-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        if (Model.Category == cat) { <option value="@cat" selected>@cat</option> }
                        else { <option value="@cat">@cat</option> }
                    }
                </select>
            </div>

            <div class="sw-filter-group">
                <label class="sw-filter-label">Priority</label>
                <select name="priority" class="sw-select">
                    <option value="">All Priorities</option>
                    @if (Model.Priority == "high")   { <option value="high"   selected>High</option>   }
                    else                             { <option value="high">High</option>               }
                    @if (Model.Priority == "medium") { <option value="medium" selected>Medium</option> }
                    else                             { <option value="medium">Medium</option>           }
                    @if (Model.Priority == "low")    { <option value="low"    selected>Low</option>    }
                    else                             { <option value="low">Low</option>                 }
                </select>
            </div>

            <div class="sw-filter-group">
                <label class="sw-filter-label">Status</label>
                <select name="status" class="sw-select">
                    <option value="">All Statuses</option>
                    @foreach (var st in statuses)
                    {
                        if (Model.Status == st) { <option value="@st" selected>@st</option> }
                        else { <option value="@st">@st</option> }
                    }
                </select>
            </div>

            <div class="sw-filter-group">
                <label class="sw-filter-label">Sort By</label>
                <select name="sortBy" class="sw-select">
                    @foreach (var opt in sortOptions)
                    {
                        if (Model.SortBy == opt.Value) { <option value="@opt.Value" selected>@opt.Label</option> }
                        else { <option value="@opt.Value">@opt.Label</option> }
                    }
                </select>
            </div>

            <div class="sw-filter-actions">
                <button type="submit" class="sw-btn sw-btn-primary">
                    <i data-lucide="filter"></i>
                    Apply
                </button>
                <a class="sw-btn sw-btn-secondary" asp-controller="Complain" asp-action="List">
                    Clear
                </a>
            </div>

        </div>
    </form>
</div>

<!-- Table Card -->
<div class="sw-card" style="padding: 0; overflow: hidden;">

    <!-- Table Meta -->
    <div class="sw-table-meta">
        <span class="sw-result-count">
            @if (Model.FilteredCount == 0)
            {
                <span>No results found</span>
            }
            else
            {
                var from = (Model.CurrentPage - 1) * Model.PageSize + 1;
                var to   = Math.Min(Model.CurrentPage * Model.PageSize, Model.FilteredCount);
                <span>Showing <strong>@from–@to</strong> of <strong>@Model.FilteredCount</strong> @(Model.FilteredCount == 1 ? "complaint" : "complaints")</span>
            }
        </span>
        @if (!string.IsNullOrEmpty(Model.Department) || !string.IsNullOrEmpty(Model.Priority) ||
             !string.IsNullOrEmpty(Model.Category)   || !string.IsNullOrEmpty(Model.Status)   ||
             !string.IsNullOrEmpty(Model.SortBy))
        {
            <a class="sw-btn sw-btn-secondary" style="padding: 5px 14px; font-size: 12px;"
               asp-controller="Complain" asp-action="List">
                <i data-lucide="x"></i>
                Clear filters
            </a>
        }
    </div>

    @if (Model.Complains.Count == 0)
    {
        <div class="sw-empty-state">
            <div class="sw-empty-icon">
                <i data-lucide="inbox"></i>
            </div>
            <h3>No complaints found</h3>
            @if (!string.IsNullOrEmpty(Model.Department) || !string.IsNullOrEmpty(Model.Priority) ||
                 !string.IsNullOrEmpty(Model.Category)   || !string.IsNullOrEmpty(Model.Status))
            {
                <p>No complaints match your current filters. Try adjusting or clearing them.</p>
                <a class="sw-btn sw-btn-secondary" asp-controller="Complain" asp-action="List">Clear Filters</a>
            }
            else
            {
                <p>No complaints have been submitted yet. Be the first to submit one.</p>
                <a class="sw-btn sw-btn-primary" asp-controller="Complain" asp-action="Index">
                    <i data-lucide="plus"></i>
                    Submit Complaint
                </a>
            }
        </div>
    }
    else
    {
        <div class="sw-table-wrapper">
            <table class="sw-table">
                <thead>
                    <tr>
                        <th>Complainant</th>
                        <th>Category</th>
                        <th>Department</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Sentiment</th>
                        <th>Submitted</th>
                        <th>Complaint</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Complains)
                    {
                        var sentScore   = item.SentimentScore ?? 0m;
                        var sentPct     = (sentScore * 100).ToString("F0");
                        var sentColor   = sentScore >= 0.7m ? "#10b981" : sentScore >= 0.4m ? "#f59e0b" : "#ef4444";
                        var priorityKey = (item.Priority ?? "low").ToLower();
                        var priorityCap = char.ToUpper(priorityKey[0]) + priorityKey[1..];
                        var statusVal   = item.Status ?? "Open";
                        var statusClass = statusVal switch
                        {
                            "Resolved"    => "sw-badge-status-resolved",
                            "In Progress" => "sw-badge-status-inprogress",
                            _             => "sw-badge-status-open"
                        };
                        var safeResponse = (item.AIDraftedResponse ?? "No AI response generated.").Replace("\"", "&quot;");

                        <tr>
                            <td>
                                <span class="sw-complainant-name">@item.Name</span>
                                <span class="sw-complainant-email">@item.Email</span>
                            </td>
                            <td>
                                <span class="sw-badge sw-badge-category" title="@item.Category">@(item.Category ?? "—")</span>
                            </td>
                            <td>
                                <span class="sw-badge sw-badge-dept" title="@item.Department">@item.Department</span>
                            </td>
                            <td>
                                <span class="sw-badge sw-badge-@priorityKey">@priorityCap</span>
                            </td>
                            <td>
                                <span class="sw-badge @statusClass">@statusVal</span>
                            </td>
                            <td>
                                <div class="sw-sentiment">
                                    <div class="sw-sentiment-bar">
                                        <div class="sw-sentiment-fill"
                                             style="width: @sentPct%; background-color: @sentColor;"></div>
                                    </div>
                                    <span class="sw-sentiment-text">
                                        @item.SentimentLabel
                                        <span style="color: #d1d5db; margin: 0 2px;">·</span>
                                        @sentPct%
                                    </span>
                                </div>
                            </td>
                            <td style="white-space: nowrap;">
                                <span style="font-size: 13px; font-weight: 500; color: #111827;">
                                    @item.CreatedAt.ToString("MMM d, yyyy")
                                </span>
                                <span style="display: block; font-size: 11px; color: #9ca3af; margin-top: 2px;">
                                    @item.CreatedAt.ToString("h:mm tt") UTC
                                </span>
                            </td>
                            <td>
                                <p class="sw-complaint-preview">@item.ComplainText</p>
                            </td>
                            <td>
                                <button type="button"
                                        class="sw-btn sw-btn-primary sw-btn-sm"
                                        onclick="openResponseModal('@safeResponse', '@System.Web.HttpUtility.JavaScriptStringEncode(item.Name)')">
                                    <i data-lucide="send"></i>
                                    Send Response
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="sw-pagination">

                @if (Model.CurrentPage <= 1)
                {
                    <span class="sw-page-link disabled"><i data-lucide="chevron-left"></i></span>
                }
                else
                {
                    <a class="sw-page-link"
                       asp-controller="Complain" asp-action="List"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-department="@Model.Department"
                       asp-route-priority="@Model.Priority"
                       asp-route-category="@Model.Category"
                       asp-route-status="@Model.Status">
                        <i data-lucide="chevron-left"></i>
                    </a>
                }

                @if (startPage > 1)
                {
                    <a class="sw-page-link"
                       asp-controller="Complain" asp-action="List"
                       asp-route-page="1"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-department="@Model.Department"
                       asp-route-priority="@Model.Priority"
                       asp-route-category="@Model.Category"
                       asp-route-status="@Model.Status">1</a>
                    @if (startPage > 2) { <span class="sw-page-ellipsis">…</span> }
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a class="sw-page-link @(i == Model.CurrentPage ? "active" : "")"
                       asp-controller="Complain" asp-action="List"
                       asp-route-page="@i"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-department="@Model.Department"
                       asp-route-priority="@Model.Priority"
                       asp-route-category="@Model.Category"
                       asp-route-status="@Model.Status">@i</a>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1) { <span class="sw-page-ellipsis">…</span> }
                    <a class="sw-page-link"
                       asp-controller="Complain" asp-action="List"
                       asp-route-page="@Model.TotalPages"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-department="@Model.Department"
                       asp-route-priority="@Model.Priority"
                       asp-route-category="@Model.Category"
                       asp-route-status="@Model.Status">@Model.TotalPages</a>
                }

                @if (Model.CurrentPage >= Model.TotalPages)
                {
                    <span class="sw-page-link disabled"><i data-lucide="chevron-right"></i></span>
                }
                else
                {
                    <a class="sw-page-link"
                       asp-controller="Complain" asp-action="List"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-department="@Model.Department"
                       asp-route-priority="@Model.Priority"
                       asp-route-category="@Model.Category"
                       asp-route-status="@Model.Status">
                        <i data-lucide="chevron-right"></i>
                    </a>
                }

            </div>
        }

        <div style="padding: 12px 24px; border-top: 1px solid #f3f4f6; font-size: 12px; color: #9ca3af; text-align: center;">
            Page @Model.CurrentPage of @Model.TotalPages
        </div>
    }

</div>

<!-- Send Response Modal -->
<div id="response-modal-backdrop" class="sw-modal-backdrop" style="display:none;" onclick="closeResponseModal()"></div>
<div id="response-modal" class="sw-modal" style="display:none;" role="dialog" aria-modal="true">
    <div class="sw-modal-header">
        <div>
            <h3 class="sw-modal-title">
                <i data-lucide="mail"></i>
                AI Drafted Response
            </h3>
            <p class="sw-modal-subtitle" id="modal-customer-name"></p>
        </div>
        <button type="button" class="sw-modal-close" onclick="closeResponseModal()" aria-label="Close">
            <i data-lucide="x"></i>
        </button>
    </div>
    <div class="sw-modal-body">
        <p id="modal-response-text"></p>
    </div>
    <div class="sw-modal-footer">
        <button type="button" class="sw-btn sw-btn-secondary" onclick="closeResponseModal()">
            <i data-lucide="x"></i>
            Close
        </button>
        <button type="button" class="sw-btn sw-btn-primary" onclick="sendResponse()">
            <i data-lucide="send"></i>
            Send
        </button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    window.openResponseModal = function (response, customerName) {
        document.getElementById('modal-response-text').textContent = response;
        document.getElementById('modal-customer-name').textContent = 'To: ' + customerName;
        document.getElementById('response-modal-backdrop').style.display = 'block';
        document.getElementById('response-modal').style.display = 'flex';
        lucide.createIcons();
    };

    window.closeResponseModal = function () {
        document.getElementById('response-modal-backdrop').style.display = 'none';
        document.getElementById('response-modal').style.display = 'none';
    };

    window.sendResponse = function () {
        closeResponseModal();
    };

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeResponseModal();
    });
})();
</script>
}
