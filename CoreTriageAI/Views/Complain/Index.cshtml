@{
    ViewData["Title"] = "Submit a Complaint";
}

<div class="sw-page-header">
    <h1>Submit a Complaint</h1>
    <p>Fill in the form below and our AI will route and prioritize your complaint automatically.</p>
</div>

<div style="max-width: 640px;">

    <div id="success-alert" class="sw-alert sw-alert-success" role="alert" style="display:none;">
        <i data-lucide="circle-check"></i>
        <span>Your complaint has been logged. Our team will contact you soon.</span>
    </div>

    <div id="error-alert" class="sw-alert sw-alert-error" role="alert" style="display:none;">
        <i data-lucide="alert-circle"></i>
        <span id="error-message">Something went wrong. Please try again.</span>
    </div>

    <div class="sw-card" style="position: relative;">

        <div id="spinner-overlay" class="sw-spinner-overlay" style="display:none;">
            <div class="sw-spinner"></div>
            <span class="sw-spinner-label">Analyzing your complaint&hellip;</span>
        </div>

        <div class="sw-card-header">
            <div class="sw-card-icon">
                <i data-lucide="message-square-warning"></i>
            </div>
            <div>
                <h2>Complaint Details</h2>
                <p>All fields marked <span style="color:#ef4444;">*</span> are required.</p>
            </div>
        </div>

        <form id="complain-form" novalidate>
            @Html.AntiForgeryToken()

            <div class="sw-form-row">
                <div class="sw-form-group">
                    <label for="Name" class="sw-label">Name <span class="required">*</span></label>
                    <div class="sw-input-icon">
                        <i data-lucide="user" class="icon"></i>
                        <input id="Name" name="Name" type="text" class="sw-input"
                               placeholder="Your full name" autocomplete="name" />
                    </div>
                    <span class="sw-invalid-feedback" id="Name-error"></span>
                </div>

                <div class="sw-form-group">
                    <label for="Email" class="sw-label">Email <span class="required">*</span></label>
                    <div class="sw-input-icon">
                        <i data-lucide="mail" class="icon"></i>
                        <input id="Email" name="Email" type="email" class="sw-input"
                               placeholder="your@email.com" autocomplete="email" />
                    </div>
                    <span class="sw-invalid-feedback" id="Email-error"></span>
                </div>
            </div>

            <div class="sw-form-group">
                <label for="PhoneNumber" class="sw-label">Phone Number <span class="required">*</span></label>
                <div class="sw-input-icon">
                    <i data-lucide="phone" class="icon"></i>
                    <input id="PhoneNumber" name="PhoneNumber" type="tel" class="sw-input"
                           placeholder="+92 300 0000000" autocomplete="tel" />
                </div>
                <span class="sw-invalid-feedback" id="PhoneNumber-error"></span>
            </div>

            <div class="sw-form-group">
                <label for="ComplainText" class="sw-label">Complaint <span class="required">*</span></label>
                <textarea id="ComplainText" name="ComplainText" class="sw-textarea"
                          rows="5" placeholder="Describe your complaint in detail..."></textarea>
                <span class="sw-invalid-feedback" id="ComplainText-error"></span>
            </div>

            <div style="margin-top: 8px;">
                <button type="submit" id="submit-btn" class="sw-btn sw-btn-primary sw-btn-full sw-btn-lg">
                    <i data-lucide="send"></i>
                    Submit Complaint
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const form        = document.getElementById('complain-form');
    const spinner     = document.getElementById('spinner-overlay');
    const successEl   = document.getElementById('success-alert');
    const errorEl     = document.getElementById('error-alert');
    const errorMsg    = document.getElementById('error-message');
    const submitBtn   = document.getElementById('submit-btn');

    const fields = [
        { id: 'Name',         label: 'Name' },
        { id: 'Email',        label: 'Email' },
        { id: 'PhoneNumber',  label: 'Phone number' },
        { id: 'ComplainText', label: 'Complaint' }
    ];

    function clearErrors() {
        fields.forEach(function (f) {
            document.getElementById(f.id).classList.remove('is-invalid');
            document.getElementById(f.id + '-error').textContent = '';
        });
    }

    function validate() {
        var valid = true;
        fields.forEach(function (f) {
            var el  = document.getElementById(f.id);
            var err = document.getElementById(f.id + '-error');
            var val = el.value.trim();
            if (!val) {
                el.classList.add('is-invalid');
                err.textContent = f.label + ' is required.';
                valid = false;
            } else if (f.id === 'Email' && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(val)) {
                el.classList.add('is-invalid');
                err.textContent = 'Please enter a valid email address.';
                valid = false;
            }
        });
        return valid;
    }

    function showSpinner() {
        spinner.style.display = 'flex';
        submitBtn.disabled = true;
    }

    function hideSpinner() {
        spinner.style.display = 'none';
        submitBtn.disabled = false;
    }

    form.addEventListener('submit', async function (e) {
        e.preventDefault();
        clearErrors();
        successEl.style.display = 'none';
        errorEl.style.display   = 'none';

        if (!validate()) return;

        showSpinner();

        var token = form.querySelector('[name="__RequestVerificationToken"]').value;

        try {
            var response = await fetch('/Complain/Submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: new URLSearchParams({
                    Name:         document.getElementById('Name').value.trim(),
                    Email:        document.getElementById('Email').value.trim(),
                    PhoneNumber:  document.getElementById('PhoneNumber').value.trim(),
                    ComplainText: document.getElementById('ComplainText').value.trim()
                }).toString()
            });

            var result = await response.json();
            hideSpinner();

            if (result.success) {
                form.reset();
                successEl.style.display = 'flex';
                successEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
                errorMsg.textContent    = result.error || 'Something went wrong. Please try again.';
                errorEl.style.display  = 'flex';
            }
        } catch (_) {
            hideSpinner();
            errorMsg.textContent   = 'A network error occurred. Please check your connection and try again.';
            errorEl.style.display  = 'flex';
        }
    });
})();
</script>
}
