<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoreTriageAI</title>

    <!-- Google Fonts - Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Lucide Icons -->
    <script src="https://cdn.jsdelivr.net/npm/lucide@latest"></script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoreTriageAI.styles.css" asp-append-version="true" />
</head>
<body>

    <header class="sw-header">
        <div class="sw-header-inner">
            <a class="sw-brand" asp-area="" asp-controller="Complain" asp-action="Index">
                <i data-lucide="shield-alert"></i>
                CoreTriageAI
            </a>

            <button class="sw-nav-toggler d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#swNav" aria-expanded="false" aria-label="Toggle navigation">
                <i data-lucide="menu"></i>
            </button>

            <nav class="sw-nav collapse" id="swNav">
                <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <i data-lucide="layout-dashboard"></i>
                    Dashboard
                </a>
                <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complain" ? "active" : "")"
                   asp-area="" asp-controller="Complain" asp-action="Index">
                    <i data-lucide="message-square-warning"></i>
                    Complain
                </a>
            </nav>
        </div>
    </header>

    <main class="sw-main">
        <div class="sw-container">
            @RenderBody()
        </div>
    </main>

    <footer class="sw-footer">
        <div class="sw-container">
            <span>&copy; @DateTime.Now.Year CoreTriageAI. All rights reserved.</span>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Initialize Lucide Icons -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
